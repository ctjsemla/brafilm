{
  "name": "brafilm",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "predev": "node scripts/ensure-banners.mjs",
    "build": "vite build",
    "prebuild": "node scripts/ensure-banners.mjs",
    "build:pages": "GITHUB_PAGES=true vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "deploy": "npm run build:pages && npx gh-pages -d dist",
    "banners:generate": "node scripts/generate-promo-gifs.mjs"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "gh-pages": "^6.3.0",
    "gifenc": "^1.0.3",
    "vite": "^6.3.5"
  }
}
